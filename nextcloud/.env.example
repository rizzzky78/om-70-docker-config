# =============================================================================
# Nextcloud Docker Configuration
# =============================================================================
# Copy this file to .env and fill in the values before deploying.
# Do NOT commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# MariaDB Configuration
# -----------------------------------------------------------------------------

# Root password for MariaDB (required)
MYSQL_ROOT_PASSWORD=changeme_root_password

# Database name for Nextcloud
MYSQL_DATABASE=nextcloud

# Database user for Nextcloud
MYSQL_USER=nextcloud

# Database user password
MYSQL_PASSWORD=changeme_user_password

# -----------------------------------------------------------------------------
# Nextcloud Admin Configuration
# -----------------------------------------------------------------------------

# Nextcloud admin username (set during first run)
NEXTCLOUD_ADMIN_USER=admin

# Nextcloud admin password (set during first run)
NEXTCLOUD_ADMIN_PASSWORD=changeme_admin_password

# -----------------------------------------------------------------------------
# Nextcloud Trusted Domains
# -----------------------------------------------------------------------------
# Space-separated list of trusted domains
# Example: "localhost nextcloud.example.com 192.168.1.100"
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# -----------------------------------------------------------------------------
# Redis Configuration (External Container)
# -----------------------------------------------------------------------------
# Hostname or container name of the external Redis instance
REDIS_HOST=redis

# Redis port (default: 6379)
REDIS_HOST_PORT=6379

# Redis password (must match your external Redis container password)
REDIS_HOST_PASSWORD=changeme_redis_password

# -----------------------------------------------------------------------------
# PHP Configuration
# -----------------------------------------------------------------------------

# PHP memory limit (default: 512M)
PHP_MEMORY_LIMIT=512M

# PHP upload limit - affects post_max_size and upload_max_filesize (default: 512M)
PHP_UPLOAD_LIMIT=512M

# Apache body limit in bytes (default: 1073741824 = 1GiB, 0 = unlimited)
APACHE_BODY_LIMIT=1073741824

# -----------------------------------------------------------------------------
# Reverse Proxy Configuration (optional)
# -----------------------------------------------------------------------------
# Uncomment and configure if Nextcloud is behind a reverse proxy

# Set to 1 to disable Apache rewrite IP
#APACHE_DISABLE_REWRITE_IP=1

# Space-separated list of trusted proxy IPs/CIDRs
#TRUSTED_PROXIES=172.16.0.0/12

# Override host (hostname of your reverse proxy)
#OVERWRITEHOST=nextcloud.example.com

# Override protocol (http or https)
#OVERWRITEPROTOCOL=https

# Override CLI URL
#OVERWRITECLIURL=https://nextcloud.example.com

# -----------------------------------------------------------------------------
# Docker Compose Configuration
# -----------------------------------------------------------------------------

# Project namespace (defaults to folder name if not set)
COMPOSE_PROJECT_NAME=nextcloud
