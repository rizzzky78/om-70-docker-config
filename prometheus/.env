# =============================================================================
# Prometheus & Grafana Monitoring Stack — Active Configuration
# =============================================================================
# ⚠ Do not commit this file to version control.
# =============================================================================

# Grafana Admin Credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_in_production

# Grafana Port (host)
GRAFANA_PORT=3001

# Prometheus Port (host)
PROMETHEUS_PORT=9090

# Prometheus Retention
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=0

# Scrape / Evaluation intervals
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# Resource Limits
PROMETHEUS_MEM_LIMIT=2g
PROMETHEUS_MEM_RESERVATION=512m
PROMETHEUS_CPUS=1.0

GRAFANA_MEM_LIMIT=512m
GRAFANA_MEM_RESERVATION=128m
GRAFANA_CPUS=0.5

# Grafana Anonymous Access
GF_AUTH_ANONYMOUS_ENABLED=false
