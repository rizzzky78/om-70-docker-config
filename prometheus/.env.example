# =============================================================================
# Prometheus & Grafana Monitoring Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠ Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Grafana Admin Credentials
# -----------------------------------------------------------------------------
# The admin username and password for the Grafana web UI.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# Grafana Server Settings
# -----------------------------------------------------------------------------
# The port Grafana will be exposed on the host.
GRAFANA_PORT=3001

# Optional: Set the domain Grafana is served from (used for absolute URLs).
# GF_SERVER_DOMAIN=monitoring.example.com
# GF_SERVER_ROOT_URL=https://monitoring.example.com

# -----------------------------------------------------------------------------
# Prometheus Settings
# -----------------------------------------------------------------------------
# The port Prometheus will be exposed on the host.
PROMETHEUS_PORT=9090

# How long Prometheus retains data. Use Prometheus duration notation:
# e.g. 15d, 30d, 90d
PROMETHEUS_RETENTION_TIME=30d

# Maximum size of the TSDB storage. 0 = no limit.
# e.g. 10GB, 20GB
PROMETHEUS_RETENTION_SIZE=0

# Scrape interval — how often Prometheus polls targets.
PROMETHEUS_SCRAPE_INTERVAL=15s

# Evaluation interval — how often alert rules are evaluated.
PROMETHEUS_EVALUATION_INTERVAL=15s

# -----------------------------------------------------------------------------
# Resource Limits (Docker)
# -----------------------------------------------------------------------------
# Adjust based on your host machine capacity.
PROMETHEUS_MEM_LIMIT=2g
PROMETHEUS_MEM_RESERVATION=512m
PROMETHEUS_CPUS=1.0

GRAFANA_MEM_LIMIT=512m
GRAFANA_MEM_RESERVATION=128m
GRAFANA_CPUS=0.5

# -----------------------------------------------------------------------------
# Grafana Anonymous Access (disable in production)
# -----------------------------------------------------------------------------
GF_AUTH_ANONYMOUS_ENABLED=false

# -----------------------------------------------------------------------------
# Grafana SMTP (optional — for alert email notifications)
# -----------------------------------------------------------------------------
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.example.com:587
# GF_SMTP_USER=alerts@example.com
# GF_SMTP_PASSWORD=your_smtp_password
# GF_SMTP_FROM_ADDRESS=alerts@example.com
# GF_SMTP_FROM_NAME=Grafana
